{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workshopConfig": {
      "value": {
        "//": "Central configuration. Change anything here BEFORE running deploy. Every name, region, SKU, and model is configurable.",

        "workshopName": "pepsi-ai-workshop",
        "environmentName": "sandbox",

        "//region": "primaryLocation hosts most resources. OpenAI and SQL may use different regions for VECTOR/model availability.",
        "primaryLocation": "eastus2",

        "tags": {
          "Project": "PepsiCo AI Workshop",
          "Environment": "Sandbox",
          "ManagedBy": "azd"
        },

        "//features": "Turn whole resource groups on/off. enableDataPlatform covers Pradipta's labs (SQL, AOAI, AML, Storage). enableFabric provisions a Fabric capacity.",
        "features": {
          "enableAiFoundry": true,
          "enableAiSearch": true,
          "enableContainerApps": true,
          "enableCosmosDb": true,
          "enableDataPlatform": true,
          "enableFabric": false
        },

        "//dataPlatform": "Pradipta's Data Platform resources (Labs 01-04). Azure OpenAI, Azure SQL (VECTOR), AML, Storage, Key Vault, Fabric.",
        "dataPlatform": {
          "//adminObjectId": "Entra Object ID of the workshop operator/admin. Used as SQL Entra admin, Key Vault admin, and Fabric capacity admin.",
          "adminObjectId": "<REPLACE-WITH-YOUR-ENTRA-OBJECT-ID>",
          "aadAdminLogin": "<REPLACE-WITH-YOUR-UPN>",

          "//openAi": "Azure OpenAI for embedding (Lab 03) and chat (Data Agent). Use a region that supports text-embedding-3-small.",
          "openAiLocation": "eastus2",
          "openAiEmbedDeploymentName": "text-embedding-3-small",
          "openAiChatDeploymentName": "gpt-4o-mini",
          "openAiDeployments": [
            {
              "name": "text-embedding-3-small",
              "model": "text-embedding-3-small",
              "version": "1",
              "skuName": "Standard",
              "capacity": 60
            },
            {
              "name": "gpt-4o-mini",
              "model": "gpt-4o-mini",
              "version": "2024-07-18",
              "skuName": "GlobalStandard",
              "capacity": 60
            }
          ],

          "//sql": "Azure SQL Database with VECTOR type support for Lab 03. Use a region where VECTOR is GA.",
          "sqlLocation": "eastus2",
          "sqlDatabaseName": "db_pepsi_rag",

          "//aml": "Azure Machine Learning workspace + compute for Lab 04.",
          "amlComputeName": "cpu-cluster",
          "amlComputeVmSize": "Standard_DS3_v2",
          "amlComputeMinNodes": 0,
          "amlComputeMaxNodes": 2,

          "//fabric": "Fabric capacity SKU. Set enableFabric=true to provision via Bicep. Otherwise provision manually in the Fabric admin portal.",
          "fabricSkuName": "F2"
        },

        "aiFoundry": {
          "//locations": "Foundry runs in these regions. FIRST = primary (feeds the workshop .env). SECOND = secondary full stack for model-quota overflow / fallback.",
          "locations": [
            "northcentralus",
            "swedencentral"
          ],
          "sku": "S0",
          "chatDeploymentName": "gpt-4.1-mini",
          "embeddingDeploymentName": "text-embedding-3-small",
          "deployments": [
            {
              "name": "gpt-5.4-mini",
              "model": "gpt-5.4-mini",
              "version": "2026-03-17",
              "skuName": "GlobalStandard",
              "capacity": 1000
            },
            {
              "name": "gpt-5.4-nano",
              "model": "gpt-5.4-nano",
              "version": "2026-03-17",
              "skuName": "GlobalStandard",
              "capacity": 5000
            },
            {
              "name": "gpt-4.1-mini",
              "model": "gpt-4.1-mini",
              "version": "2025-04-14",
              "skuName": "GlobalStandard",
              "capacity": 1163
            },
            {
              "name": "text-embedding-3-small",
              "model": "text-embedding-3-small",
              "version": "1",
              "skuName": "GlobalStandard",
              "capacity": 425
            }
          ]
        },

        "aiSearch": {
          "sku": "basic",
          "replicaCount": 1,
          "partitionCount": 1,
          "semanticSearch": "free"
        },

        "containerRegistry": {
          "sku": "Basic"
        },

        "containerApps": {
          "logRetentionInDays": 30,
          "workloadProfiles": []
        },

        "cosmosDb": {
          "databaseName": "zava",
          "salesContainerName": "sales",
          "inventoryContainerName": "inventory",
          "marketingContainerName": "marketing_campaigns",
          "containers": [
            { "name": "sales", "partitionKey": "/id", "throughput": 400 },
            { "name": "inventory", "partitionKey": "/id", "throughput": 400 },
            { "name": "marketing_campaigns", "partitionKey": "/id", "throughput": 400 }
          ]
        }
      }
    }
  }
}
