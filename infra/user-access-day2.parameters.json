{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workshopUsers": {
      "value": [
        {
          "//": "Replace with real Entra user Object IDs or Security Group IDs",
          "principalId": "00000000-0000-0000-0000-000000000000",
          "principalType": "Group"
        }
      ]
    },
    "userAccess": {
      "value": {
        "//": "Control which Day 2 resources participants can access",
        "enableAzureOpenAI": true,
        "enableAzureML": true,
        "enableStorage": true,
        "enableKeyVault": true,
        "enablePostgreSQL": false
      }
    }
  }
}
